#!/data/data/com.termux/files/usr/bin/bash

set -e

AI_HOME="$HOME/AIFT/runtime/ai"
LLAMA="$HOME/Aetherion/llama.cpp/build/bin/llama-server"
MODEL="$AI_HOME/models/aetherion.gguf"
LOG="$AI_HOME/logs/aetherion.log"

if [ ! -f "$MODEL" ]; then
    echo "ERROR: Missing GGUF model:"
    echo "$MODEL"
    exit 1
fi

echo "Starting Aetherion Local Intelligence..."

nohup "$LLAMA" \
-m "$MODEL" \
--host 127.0.0.1 \
--port 8080 \
--ctx-size 2048 \
--threads 8 \
--threads-batch 8 \
--batch-size 256 \
--flash-attn auto \
> "$LOG" 2>&1 &

echo $! > "$AI_HOME/aetherion.pid"

echo "Aetherion AI ONLINE"
echo "PID: $(cat "$AI_HOME/aetherion.pid")"
echo "API: http://127.0.0.1:8080"
