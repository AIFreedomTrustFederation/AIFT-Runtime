#!/data/data/com.termux/files/usr/bin/bash

echo "========================================"
echo " Aetherion Validation Engine"
echo " Mapping → Execution Readiness"
echo "========================================"

REGISTRY="$HOME/AIFT/registry"

INPUT="$REGISTRY/execution-mappings.json"
OUTPUT="$REGISTRY/validation-results.json"
MD="$REGISTRY/validation-results.md"

if [ ! -f "$INPUT" ]; then
    echo "Missing execution mappings."
    exit 1
fi

python3 <<PY
import json
from datetime import datetime

registry="$REGISTRY"

with open("$INPUT") as f:
    data=json.load(f)

results=[]

for item in data.get("execution_mappings", []):

    tools=item.get("candidate_tools", [])

    valid_tools=[
        t for t in tools
        if "node_modules" not in t.get("path","")
        and ".git" not in t.get("path","")
    ]

    results.append({
        "objective": item.get("objective"),
        "action": item.get("action"),
        "status":"validated",
        "execution_authority":"governed",
        "checks":{
            "snapshot_required":True,
            "dependency_check":True,
            "rollback_required":item.get("rollback_required",False),
            "post_execution_test_required":True,
            "candidate_tools_found":len(valid_tools),
            "filtered_invalid_tools":len(tools)-len(valid_tools)
        },
        "execution_candidates":valid_tools[:5]
    })

output={
    "identity":{
        "name":"Aetherion",
        "system":"Federated Cognitive Runtime"
    },
    "timestamp":datetime.utcnow().isoformat()+"Z",
    "validation_summary":{
        "validated":len(results),
        "ready_for_execution":len(results)
    },
    "validated_proposals":results,
    "next_stage":"controlled execution"
}

with open("$OUTPUT","w") as f:
    json.dump(output,f,indent=2)

with open("$MD","w") as f:
    f.write("# Aetherion Validation Results\n\n")
    f.write("Status: Ready for controlled execution\n\n")
    for r in results:
        f.write("## "+str(r["objective"])+"\n")
        f.write("- Status: validated\n")
        f.write("- Rollback: required\n\n")
PY

echo "Generated:"
echo "validation-results.json"
echo "validation-results.md"

echo "========================================"
echo " ✓ VALIDATION COMPLETE"
echo "========================================"
