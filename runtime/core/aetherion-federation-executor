#!/data/data/com.termux/files/usr/bin/bash

REGISTRY="$HOME/AIFT/registry"

INPUT="$REGISTRY/orchestration-runtime-result.json"
OUTPUT="$REGISTRY/execution-history.json"

echo "========================================"
echo " Aetherion Federation Executor"
echo " Hardened Execution Layer"
echo "========================================"

python3 <<PY
import json
import uuid
from datetime import datetime, timezone

with open("$INPUT") as f:
    plan=json.load(f)

trace=str(uuid.uuid4())

authorized=plan.get("execution",{}).get("authorized",False)

result={
    "trace_id":trace,
    "timestamp":datetime.now(timezone.utc).isoformat(),
    "objective":plan.get("objective","unknown"),
    "repository":plan.get("routing",{}).get("repository"),
    "action":plan.get("decision",{}).get("action"),
    "status":"execution_completed" if authorized else "blocked",
    "validation_required":plan.get("decision",{}).get("validation_required",True),
    "rollback_required":plan.get("decision",{}).get("rollback_required",True)
}

try:
    with open("$OUTPUT") as f:
        history=json.load(f)
except:
    history={}


# Repair legacy formats
if not isinstance(history, dict):
    history={
        "identity":{
            "name":"Aetherion",
            "system":"Federated Cognitive Runtime"
        },
        "executions":[]
    }

if "executions" not in history or not isinstance(history["executions"], list):
    history["executions"]=[]


history["executions"].append(result)

history["last_execution"]=datetime.now(timezone.utc).isoformat()

with open("$OUTPUT","w") as f:
    json.dump(history,f,indent=2)

print("Execution recorded")
print("Status:",result["status"])
print("Trace:",trace)

PY

echo "========================================"
echo " ✓ FEDERATION EXECUTOR COMPLETE"
echo "========================================"
